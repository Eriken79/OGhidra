# OGhidra Configuration File


# ===== LLM PROVIDER (choose one) =====

# Active LLM Provider ('ollama', 'external', or 'custom_api')
LLM_PROVIDER=external

# --- Option 1: External API (Google Gemini, OpenAI, etc.) ---
EXTERNAL_PROVIDER=google
EXTERNAL_API_KEY=YOUR_API_KEY_HERE
EXTERNAL_MODEL=gemini-3-flash-preview
EXTERNAL_EMBEDDING_MODEL=gemini-embedding-001
EXTERNAL_TIMEOUT=120
EXTERNAL_TEMPERATURE=0.7
EXTERNAL_MAX_TOKENS=8192

# --- Option 2: Ollama (local models) ---
OLLAMA_BASE_URL=http://localhost:11434/
OLLAMA_MODEL=gemma3:27b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300
# Optional: username/password for authenticated Ollama hosts
# OLLAMA_USERNAME=
# OLLAMA_PASSWORD=

# --- Option 3: Custom OpenAI-compatible API ---
# Set LLM_PROVIDER=custom_api to use this configuration
CUSTOM_API_URL=https://api.example.com/v1/chat/completions
CUSTOM_API_KEY=your-api-key-here
CUSTOM_API_MODEL=your-model-name
CUSTOM_API_EMBEDDING_MODEL=your-embedding-model
CUSTOM_API_TIMEOUT=300
CUSTOM_API_TEMPERATURE=0.7
CUSTOM_API_MAX_TOKENS=4096
CUSTOM_API_VERIFY_SSL=false
CUSTOM_API_REQUEST_DELAY=0.0
CUSTOM_API_MAX_RETRIES=3

# Throttling / concurrency control (helps prevent 429 bursts)
CUSTOM_API_MAX_CONCURRENCY=1
CUSTOM_API_GLOBAL_MIN_INTERVAL=0.0
CUSTOM_API_RESPECT_RETRY_AFTER=true
CUSTOM_API_RETRY_AFTER_MAX_SECONDS=60

# Adaptive throttling (auto-adjust on 429/503 retries)
CUSTOM_API_ADAPTIVE_THROTTLE_ENABLED=true
CUSTOM_API_ADAPTIVE_MAX_INTERVAL=10.0
CUSTOM_API_ADAPTIVE_INCREASE_FACTOR=1.5
CUSTOM_API_ADAPTIVE_DECREASE_FACTOR=0.9
CUSTOM_API_ADAPTIVE_SUCCESS_STREAK_THRESHOLD=10
CUSTOM_API_ADAPTIVE_JITTER_SECONDS=0.25


# ===== GHIDRA CONNECTION =====

GHIDRA_BASE_URL=http://localhost:8080/
GHIDRA_TIMEOUT=30


# ===== ORCHESTRATOR SETTINGS =====
# The orchestrator automatically routes queries:
#   - Conversational mode (default): single worker loop for questions/tasks
#   - Investigation mode: multi-cycle orchestrator for binary-wide analysis
#
# These are SAFETY CEILINGS only. The LLM decides when to stop.

ORCHESTRATOR_MAX_CYCLES=15          # Max investigation cycles (safety ceiling)
WORKER_DEFAULT_MAX_STEPS=20         # Max tool calls per worker (safety ceiling)

# Coverage stall: stop if no progress for N consecutive cycles
COVERAGE_STALL_THRESHOLD=3

# Doom loop: stop if same task goal repeated N times
ORCHESTRATOR_DOOM_LOOP_THRESHOLD=2

# Correlation hooks: deterministic vulnerability pattern detection
CORRELATION_HOOKS_ENABLED=true
# CUSTOM_HOOKS_DIR=              # Directory for custom hook .py files
# CUSTOM_RECIPES_DIR=            # Directory for custom recipe .py files


# ===== CONTEXT MANAGEMENT =====
# Controls how much data the AI can process per request.

# Maximum context budget in tokens (adjust to your LLM's context window)
CONTEXT_BUDGET=100000

# Enable LLM-based summarization for large results
ENABLE_RESULT_SUMMARIZATION=true

# Enable result caching
RESULT_CACHE_ENABLED=true

# Enable tiered context compression
TIERED_CONTEXT_ENABLED=true

# Worker context compaction threshold (compact older tool results after N steps)
WORKER_COMPACTION_THRESHOLD=6


# ===== LLM LOGGING =====
# Track all AI interactions for debugging

LLM_LOGGING_ENABLED=false
LLM_LOG_FILE=logs/llm_interactions.log
LLM_LOG_FORMAT=json
LLM_LOG_PROMPTS=true
LLM_LOG_RESPONSES=true
LLM_LOG_TOKENS=true
LLM_LOG_TIMING=true


# ===== SESSION COMPACTION =====
# Smart context pruning to prevent overflow

COMPACTION_ENABLED=true
COMPACTION_THRESHOLD=0.75
COMPACTION_AUTO=true
